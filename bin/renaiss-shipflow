#!/usr/bin/env bash
# Bundled ShipFlow CLI launcher — ships inside the plugin, so users don't need a
# separate `npm i -g @renaiss-shipflow/cli`. Requires node, gh, and git on PATH.
#
# Resolves the NEWEST CLI across BOTH sources (issue #307):
#   1. plugin-bundled copies   — ~/.claude/plugins/cache/renaissshipflow/shipflow/*/cli/
#      (a snapshot frozen at each plugin publish)
#   2. npm-fetched copies      — ~/.shipflow/cli/<version>/ (kept fresh by
#      bin/shipflow-cli-update, which tracks the npm registry between publishes)
# Highest semver wins, so the CLI tracks the latest release even when plugin
# publishing lags — and a newer bundled copy still wins if npm ever lags.
# (Without cross-source resolution, a stale plugin stranded users on a stale CLI
# forever — the "plugin updated but CLI is still old" family of bugs.)
set -euo pipefail

STATE_DIR="${SHIPFLOW_STATE_DIR:-$HOME/.shipflow}"

_candidates() {
  # "version<TAB>path" per candidate, both sources.
  local d v pj
  for d in "$HOME"/.claude/plugins/cache/renaissshipflow/shipflow/*/; do
    [ -f "${d}cli/dist/renaiss-shipflow.mjs" ] || continue
    pj="${d}cli/package.json"
    # `|| true`: under `set -eo pipefail` a version-less package.json would
    # otherwise kill the whole scan instead of falling back to the dir name.
    v="$(grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' "$pj" 2>/dev/null | head -1 | sed 's/.*"\([0-9][^"]*\)".*/\1/')" || true
    [ -n "$v" ] || v="$(basename "$d")" # old bundles: plugin dir version ≈ CLI version
    printf '%s\t%s\n' "$v" "${d}cli/dist/renaiss-shipflow.mjs"
  done 2>/dev/null
  for d in "$STATE_DIR"/cli/*/; do
    [ -f "${d}node_modules/@renaiss-shipflow/cli/dist/index.js" ] || continue
    printf '%s\t%s\n' "$(basename "$d")" "${d}node_modules/@renaiss-shipflow/cli/dist/index.js"
  done 2>/dev/null
  return 0
}

# `sort -V` is a GNU/BSD extension (absent on e.g. BusyBox); probe first so an
# unsupported sort degrades to the co-located bundle instead of crashing the
# launcher under `set -eo pipefail`.
_newest=""
if printf '1\n' | sort -V >/dev/null 2>&1; then
  _newest="$(_candidates | sort -V | tail -1 | cut -f2-)" || _newest=""
fi
if [ -z "${_newest:-}" ]; then
  # Fallback: the CLI co-located with this launcher.
  DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  _newest="$DIR/../cli/dist/renaiss-shipflow.mjs"
fi
exec node "$_newest" "$@"
